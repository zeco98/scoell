    "test:e2e": "jest --config test/jest-e2e.json"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma"
  },
  "dependencies": {
    "@manarah/shared": "workspace:*",
    "@nestjs/common": "11.1.6",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.6",
    "@nestjs/jwt": "11.0.0",
    "@nestjs/platform-express": "11.1.6",
    "@nestjs/swagger": "11.2.0",
    "@nestjs/throttler": "6.4.0",
    "argon2": "0.44.0",
    "cookie-parser": "1.4.7",
    "csv-parse": "5.6.0",
    "helmet": "8.1.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.10",
    "@nestjs/testing": "11.1.6",
    "@types/cookie-parser": "1.4.8",
    "@types/express": "5.0.1",
    "@types/jest": "^30.0.0",
    "@types/multer": "1.4.13",
    "@types/node": "22.15.3",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "10.9.2",
    "typescript": "5.7.3"
  }
