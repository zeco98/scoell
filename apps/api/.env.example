# للإنتاج: postgresql://user:pass@host:5432/manarah (بدّل provider في schema.prisma)
DATABASE_URL="file:./dev.db"
# أنشئ سرًا قويًا: openssl rand -hex 32
JWT_SECRET=""
JWT_EXPIRES_IN="15m"
REFRESH_TTL_DAYS="7"
PORT="3001"
CORS_ORIGINS="http://localhost:5173,tauri://localhost"
# كلمة مرور حسابات seed — يجب تغييرها عند أول دخول production
SEED_PASSWORD=""
# في الإنتاج اضبطها true لإجبار حسابات seed على تغيير كلمة المرور عند أول دخول
SEED_FORCE_PASSWORD_CHANGE="false"
# NODE_ENV=production يفعّل secure cookies ويعطّل تخطي rate-limit
NODE_ENV="development"
